# Normalize all text files to LF on commit.
# This prevents the "50 files changed" noise when switching between
# Windows (CRLF) and Linux/macOS (LF) machines.

* text=auto eol=lf

# Explicitly mark binary formats so Git never tries to diff or convert them.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
